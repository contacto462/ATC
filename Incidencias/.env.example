APP_NAME=Incidencias API
APP_ENV=dev
# PostgreSQL (recomendado para este proyecto)
# Ejemplo local:
# DATABASE_URL=postgresql+psycopg://postgres:TU_CLAVE@localhost:5432/incidencias
# Schema por defecto:
# DB_SCHEMA=public
DATABASE_URL=sqlite:///./incidencias.db
DB_SCHEMA=public
TIMEZONE=America/Santiago

# =========================
# Sync con Soporte Técnico (otro Python / otro SQL)
# =========================
# off | api | db
# AJUSTE SOPORTE REGISTRO SQL #
SUPPORT_SYNC_MODE=db

# Modo API
# SUPPORT_SYNC_API_URL=http://127.0.0.1:9000/api/incidencias/sync
# TambiÃ©n puedes poner solo la base, ej:
# SUPPORT_SYNC_API_URL=http://127.0.0.1:8000
# SUPPORT_SYNC_API_TOKEN=
SUPPORT_SYNC_API_URL=
SUPPORT_SYNC_API_TOKEN=
SUPPORT_SYNC_TIMEOUT_SEC=10

# Modo DB
# SUPPORT_DB_URL=postgresql+psycopg://postgres:TU_CLAVE@localhost:5432/helpdesk
SUPPORT_DB_URL=
SUPPORT_DB_SCHEMA=public
SUPPORT_DB_TABLE=registro

# =========================
# Correo automatico cliente (Contacto Cliente)
# =========================
# SMTP_ENABLED=true
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USERNAME=tu_correo@gmail.com
# SMTP_PASSWORD=tu_app_password
# SMTP_FROM_EMAIL=tu_correo@gmail.com
# SMTP_FROM_NAME=ATC Incidencias
# SMTP_USE_TLS=true
# SMTP_USE_SSL=false
# SMTP_TIMEOUT_SEC=20

# =========================
# IA formalizador de observaciones (Control de Protocolos)
# =========================
# Si IA_FORMALIZADOR_ENABLED=true y hay OPENAI_API_KEY, se usa IA real.
IA_FORMALIZADOR_ENABLED=true
# Si true, no guarda el registro cuando falla la IA.
IA_FORMALIZADOR_STRICT=true
OPENAI_API_KEY=
# Compatible con OpenAI y endpoints compatibles
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL_FORMALIZADOR=gpt-4.1-mini
OPENAI_TIMEOUT_SEC=25

# Google Drive: carpeta raiz para informes de protocolos (PDF)
GOOGLE_DRIVE_PROTOCOLOS_FOLDER_ID=1beVaXbf23FTHlBa2FfO1mnz55RcKf_iW
# Template fallback de Google Docs para informes de protocolos (si no se define diario/semanal)
GOOGLE_DOC_TEMPLATE_PROTOCOLOS_ID=1FWm1_UUK1zm_ouK0hT75P_sb_Xw1s5TvmF7ZN5-SV3k
# Templates separados por tipo
GOOGLE_DOC_TEMPLATE_PROTOCOLOS_DIARIO_ID=1IazJgh23qh5qHu_gSrmivcStLg4NW-qnt8nxdrHf0VE
GOOGLE_DOC_TEMPLATE_PROTOCOLOS_SEMANAL_ID=1RgaKKrsgacVEFhbfjhOn8qpqtuOQEe-cUiiE7vuZ0xQ
